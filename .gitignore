# Logs
*.log

# Environment
.env
# Per-service runtime env files (secrets). Examples (*.env.example) stay tracked,
# and apps/versions.env (image tags) is intentionally NOT ignored.
apps/env/*.env

# Hermes runtime data store (created & owned by the hermes container).
infra/hermes-data/

