# MongoDB 配置
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme-use-strong-password
MONGO_DB=finance

# Redis 配置
REDIS_PASSWORD=changeme-use-strong-password

# Grafana 配置（可选，启用监控时使用）
GRAFANA_PASSWORD=admin

# Hermes Agent 配置
# 生产环境务必替换为长随机串；用于保护 Hermes OpenAI-compatible API。
HERMES_API_SERVER_KEY=dev-hermes-api-key-change-me
HERMES_API_SERVER_ENABLED=true


