# ============================================================================
# quant-scorer.env — Service-specific config & secrets. NOT committed.
# ----------------------------------------------------------------------------
# Loaded after common.env. Shared keys (MONGO_URI / MONGO_DB / TZ) are in
# common.env. The scorer uses host.docker.internal to reach quant-api on the
# same host for internal trigger calls.
# ============================================================================

DATA_DB_NAME=quant_data
TUSHARE_TOKEN=your_tushare_token

# ----------------------------------------------------------------------------
# Portfolio research worker recovery (tools/process_portfolio_research_jobs.py)
# ----------------------------------------------------------------------------
# A running research job whose heartbeat is older than this many minutes is
# requeued back to pending on the next worker run. A background ticker keeps
# heartbeat_at fresh during long stages, so this can stay small; it is only a
# backstop for SIGKILL/OOM where graceful SIGTERM release did not run.
PORTFOLIO_RESEARCH_STALE_MINUTES=5
# Background heartbeat interval (seconds) while a job runs. Keep well below
# PORTFOLIO_RESEARCH_STALE_MINUTES so a live worker never looks stale.
PORTFOLIO_RESEARCH_HEARTBEAT_SECONDS=30
