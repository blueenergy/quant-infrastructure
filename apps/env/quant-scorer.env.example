# ============================================================================
# quant-scorer.env — Service-specific config & secrets. NOT committed.
# ----------------------------------------------------------------------------
# Loaded after common.env. Shared keys (MONGO_URI / MONGO_DB / TZ) are in
# common.env. The scorer uses host.docker.internal to reach quant-api on the
# same host for internal trigger calls.
# ============================================================================

DATA_DB_NAME=quant_data
# Required by quant-portfolio as well as quant-scorer: plan generation uses
# Tushare trade_cal to resolve future trading days such as execute_date.
TUSHARE_TOKEN=your_tushare_token

# Keep true in production so quant-portfolio fails fast if TUSHARE_TOKEN is
# accidentally removed. Set false only for local/offline tests that rely purely
# on already-loaded volume_price dates.
PORTFOLIO_REQUIRE_TUSHARE_TOKEN=true

# ----------------------------------------------------------------------------
# Portfolio research worker recovery (tools/process_portfolio_research_jobs.py)
# ----------------------------------------------------------------------------
# Research jobs are claimed by a long-running loop, not by the legacy 5-minute
# cron. Lower this for faster pickup; raise it to reduce idle DB polling writes.
PORTFOLIO_RESEARCH_LOOP_INTERVAL_SECONDS=5
# Maximum completed/failed jobs to drain before the loop sleeps again.
PORTFOLIO_RESEARCH_LOOP_LIMIT=2
# How often the loop checks for orphaned running jobs to requeue.
PORTFOLIO_RESEARCH_STALE_CHECK_INTERVAL_SECONDS=60
# A running research job whose heartbeat is older than this many minutes is
# requeued back to pending on the next worker run. A background ticker keeps
# heartbeat_at fresh during long stages, so this can stay small; it is only a
# backstop for SIGKILL/OOM where graceful SIGTERM release did not run.
PORTFOLIO_RESEARCH_STALE_MINUTES=5
# Background heartbeat interval (seconds) while a job runs. Keep well below
# PORTFOLIO_RESEARCH_STALE_MINUTES so a live worker never looks stale.
PORTFOLIO_RESEARCH_HEARTBEAT_SECONDS=30
# Concurrency for the research dataset price preload. Each symbol is an
# independent remote read; concurrent fetches cut build_dataset time. Keep at
# or below MONGO_MAX_POOL_SIZE. Set to 1 to fall back to sequential loading.
PORTFOLIO_RESEARCH_PRELOAD_WORKERS=8
