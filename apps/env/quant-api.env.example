# ============================================================================
# quant-api.env — Runtime config for quant-api / scheduler / optional MCP.
# NOT committed with real values.
# ----------------------------------------------------------------------------
# This service group intentionally uses a dedicated env file instead of
# common.env so the first migration preserves the existing quantFinance
# production .env behavior exactly. On the production host, copy the current
# /home/deployuser/quantFinance/.env values into env/quant-api.env.
# ============================================================================

# MongoDB / database names
MONGO_URI=mongodb://<user>:<password>@<DB_HOST>:27017/?authSource=admin
MONGO_DB=finance
REALTIME_DB_NAME=quant_realtime
ANALYZER_DB_NAME=quant_analyzer

# Kept for compatibility with quantFinance docker-compose/local tooling.
DOCKER_MONGO_URI=mongodb://<user>:<password>@<DB_HOST>:27017/?authSource=admin

# Auth / internal integration secrets
JWT_SECRET_KEY=change_me
HERMES_QUANT_INTERNAL_KEY=change_me

# Data providers
TUSHARE_TOKEN=your_tushare_token

# Service defaults; docker-compose.yml may override per container.
API_WORKERS=2
ENABLE_EMBEDDED_SCHEDULER=false
ENABLE_MCP_SERVER=false
