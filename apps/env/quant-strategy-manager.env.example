# ============================================================================
# quant-strategy-manager.env — Service-specific config. NOT committed.
# ----------------------------------------------------------------------------
# Loaded after common.env. Shared keys (MONGO_URI / MONGO_DB / TZ) are in
# common.env.
# ============================================================================

# API server inside the container. Host exposes this as 5001:5000.
API_PORT=5000

# Strategy configuration collection name.
CONFIG_COLLECTION=watchlist_strategies

# Config reload interval (seconds).
AUTO_RELOAD_INTERVAL=60

# Enable lifecycle management and engines.
ENABLE_LIFECYCLE=true
ENABLE_VNPY=true
ENABLE_BACKTRADER=false

# Logging defaults.
LOG_LEVEL=INFO
LOG_BACKENDS=file
LOG_FILE_PATH=/app/quant-strategy-manager/logs/app.log
