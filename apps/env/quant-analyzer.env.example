# ============================================================================
# quant-analyzer.env — Service-specific config & secrets. NOT committed.
# ----------------------------------------------------------------------------
# Loaded after common.env. All 4 analyzer replicas share this file; each
# container sets its own WORKER_ID via the compose service definition.
# WORKER_ID also falls back to the container hostname if unset (unique per
# replica), so no extra config is needed here.
# ============================================================================

DATA_DB_NAME=quant_data
TUSHARE_TOKEN=your_tushare_token

# How often each worker polls for pending tasks (seconds).
ANALYSIS_INTERVAL=300

# Limit-up attribution pipeline (quant-analyzer only).
# sector_queue: consume limit_up_sector_batch tasks instead of legacy per-stock loop.
# legacy_daily: run the old per-stock daily_limit_up batch path.
LIMIT_UP_ATTRIBUTION_MODE=sector_queue
# scheduled | realtime — only applies when LIMIT_UP_ATTRIBUTION_MODE=sector_queue.
LIMIT_UP_TRIGGER_MODE=scheduled
