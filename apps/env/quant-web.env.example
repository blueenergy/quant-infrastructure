# ============================================================================
# quant-web.env — Service-specific runtime config. NOT committed.
# ----------------------------------------------------------------------------
# Loaded by quant-web. Values mirror the old GitHub CI docker run command.
# ============================================================================

# Nginx upstreams inside quant-network.
BACKEND_URL=http://quant-api:3001
MCP_URL=http://quant-mcp-read:3002
MCP_READ_URL=http://quant-mcp-read:3002
MCP_ACTIONS_URL=http://quant-mcp-actions:3003

# External assistant / websocket worker host used by the dashboard proxy.
ASSISTANT_URL=http://115.190.172.95:8002
WS_WORKER_HOST=115.190.172.95

# TLS certs are mounted from /etc/nginx/cert on the host.
SSL_CERT=/etc/nginx/cert/wukongquant.top.pem
SSL_KEY=/etc/nginx/cert/wukongquant.top.key
