# ============================================================================
# quant-data-engine.env — Service-specific runtime config & secrets. NOT committed.
# ----------------------------------------------------------------------------
# Loaded after common.env (overrides shared keys if needed).
# Shared keys (MONGO_URI / MONGO_DB / REALTIME_DB_NAME / TZ) live in common.env;
# the remote DB address is the same for every service.
#
# This service runs with `network_mode: host` (mirrors the current CI deploy).
# That is unrelated to DB access — the DB is remote, reached as an outbound
# connection regardless of network mode.
# ============================================================================

TUSHARE_TOKEN=your_tushare_token
DATA_DB_NAME=quant_data

# Runtime profile: domestic = A-share only | overseas = global | full = all
DEPLOY_MODE=full

# Scheduler cron overrides for daily_market_sync jobs
CRON_STOCK_DAILY=00 18 * * 1-5
CRON_INDEX_DAILY=15 18 * * 1-5
CRON_ETF_DAILY=30 18 * * 1-5
CRON_FINANCIAL_DAILY=45 18 * * 1-5
CRON_MONEYFLOW_DAILY=00 19 * * 1-5
CRON_SENTIMENT_DAILY=15 19 * * 1-5
CRON_HOTSTOCK_DAILY=50 22 * * 1-5
# CRON_REALTIME_DAILY_K is only used when ENABLE_REALTIME_DAILY_K=1.
# Leave unset when disabled; start.sh removes the cron entry automatically.
CRON_REALTIME_DAILY_K=
CRON_FUND_PORTFOLIO=

# Realtime daily K snapshots and follow-up API triggers
ENABLE_REALTIME_DAILY_K=0
INTRADAY_T0_TRIGGER_URL=http://quant-api:3001/api/intraday-t0/signals/generate-all
INTRADAY_T0_TRIGGER_KEY=change_me
MARKET_INSIGHT_TRIGGER_URL=http://quant-api:3001/api/market-insights/generate-internal
MARKET_INSIGHT_TRIGGER_KEY=change_me

# Optional secondary Mongo sync
SECONDARY_MONGO_URI=
SECONDARY_MONGO_DB=finance

# Feature flags
ENABLE_X_INFLUENCER_SYNC=0
INTL_NEWS_TRANSLATE_ENABLED=1
INTL_NEWS_TRANSLATE_TARGET=zh-CN
RATE_LIMIT_PER_SEC=20
