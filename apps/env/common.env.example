# ============================================================================
# common.env — Runtime config SHARED by all app services. NOT committed.
# ----------------------------------------------------------------------------
# Copy to common.env on the production host and fill in REAL values there.
# This *.example file is a placeholder template only — real secrets live in
# common.env on the host (gitignored), never committed.
# Loaded first; per-service env/<svc>.env is loaded after and overrides these.
#
# The production database lives on a SEPARATE machine, so MONGO_URI points to
# that remote host (NOT localhost / NOT the `mongodb` service name). It is the
# same remote address for every service, hence shared here.
# ============================================================================

# Remote production DB (fill host/credentials on the prod machine).
MONGO_URI=mongodb://<user>:<password>@<DB_HOST>:27017/?authSource=admin
MONGO_DB=finance
REALTIME_DB_NAME=quant_realtime

# Timezone
TZ=Asia/Shanghai

# ---- Resource limits for stock-scoring-system containers ----
# Override these to match the host's CPU/RAM capacity.
# Defaults in docker-compose.yml assume a 4-core host.
# Docker requires cpus <= host core count; memory accepts k/m/g suffixes.
# SCORER_CPU_LIMIT=4
# SCORER_MEM_LIMIT=4g
# RESEARCHER_CPU_LIMIT=2
# RESEARCHER_MEM_LIMIT=6g
# PORTFOLIO_CPU_LIMIT=1
# PORTFOLIO_MEM_LIMIT=512m
