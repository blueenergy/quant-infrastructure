# ============================================================================
# versions.env — Desired image tags for the application stack (the "values.yaml")
# ----------------------------------------------------------------------------
# This file IS committed to git and is the single source of truth for which
# image version runs in production. App repos' CI bump the relevant line after
# pushing a new image; the infra CD workflow then rolls it out.
#
# RULES:
#   - Only put `*_IMAGE_TAG` values here. NO secrets (those live in .env).
#   - Prefer immutable tags (sha-xxxxxxx) over `latest` so deploys are
#     reproducible and rollback == git revert of this file.
#
# Used for docker-compose interpolation (see deploy.sh):
#   docker compose --env-file versions.env ...
# Only this file feeds compose ${...} interpolation. Per-service runtime
# config/secrets are injected via env_file: (env/<svc>.env) in the compose
# file, NOT through interpolation, so do not rely on a top-level .env here.
# ============================================================================

# quant-api image powers: quant-api, quant-mcp, quant-mcp-actions, quant-scheduler
QUANT_API_IMAGE_TAG=sha-6351a39

# quant-dashboard image powers: quant-web
QUANT_DASHBOARD_IMAGE_TAG=sha-948e198

QUANT_SCORER_IMAGE_TAG=sha-cbac0a3
QUANT_DATA_ENGINE_IMAGE_TAG=sha-0a794de
BACKTEST_WORKER_IMAGE_TAG=sha-d8ca581
QUANT_ANALYZER_IMAGE_TAG=sha-109564c
# Number of quant-analyzer worker replicas. deploy.sh reads this and applies
# --scale quant-analyzer=N automatically. Change here to scale up/down.
QUANT_ANALYZER_REPLICAS=4

QUANT_STRATEGY_MANAGER_IMAGE_TAG=sha-6a36914
