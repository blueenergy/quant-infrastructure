# ============================================================================
# .env — Runtime config & SECRETS for the application stack. NOT committed.
# ----------------------------------------------------------------------------
# Image versions are NOT here — they live in versions.env (committed).
# Copy this file to `.env` on the production host and fill in real secrets.
#
# NOTE on networking: all app services join `quant-network` (the infra bridge),
# so reach datastores via service names: mongodb:27017 / redis:6379.
# ============================================================================

# 数据库连接 (指向 infra 层的 mongodb 容器)
MONGO_URI=mongodb://admin:changeme@mongodb:27017/?authSource=admin
MONGO_DB=finance
ANALYZER_DB_NAME=quant_analyzer
REALTIME_DB_NAME=quant_realtime

# 密钥与 Token
JWT_SECRET_KEY=your_production_jwt_secret
TUSHARE_TOKEN=your_tushare_token
QWEN_API_KEY=your_qwen_api_key

# 时区
TZ=Asia/Shanghai

# 前端配置
BACKEND_URL=http://quant-api:3001
MCP_URL=http://quant-mcp:3002
MCP_READ_URL=http://quant-mcp:3002
MCP_ACTIONS_URL=http://quant-mcp-actions:3003
WS_WORKER_HOST=quant-strategy-manager
